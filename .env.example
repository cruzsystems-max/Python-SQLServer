# Database Configuration
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=localhost
DB_NAME=Chinook
DB_USERNAME=user
DB_PASSWORD=password
DB_TRUST_CERTIFICATE=yes

# Connection Pool Settings
POOL_MIN_SIZE=2
POOL_MAX_SIZE=10
POOL_TIMEOUT=30.0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/database.log
